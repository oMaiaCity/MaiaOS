{
	"name": "@MaiaOS/app",
	"version": "26.4.20921",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "PORT=4200 bun dev-server.js",
		"build": "cd ../.. && bun run distros:build && cd services/app && bun build.js",
		"preview": "bun server.js",
		"start": "bun server.js",
		"deploy": "./deploy.sh",
		"tauri": "tauri",
		"tauri:dev": "bun run tauri:icon && tauri dev",
