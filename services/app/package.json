		"tauri:build:debug": "bun run tauri:icon && tauri build --debug",
		"tauri:icon": "tauri icon brand/logo_app.svg -o src-tauri/icons"
	},
	"dependencies": {
		"@MaiaOS/logs": "workspace:*",
		"@MaiaOS/game": "workspace:*",
		"@MaiaOS/loader": "workspace:*",
		"@MaiaOS/peer": "workspace:*",
		"@MaiaOS/maia-ai": "workspace:*",
		"@MaiaOS/maia-distros": "workspace:*",
		"@tauri-apps/api": "^2.8.0"
	},
	"devDependencies": {
		"@tauri-apps/cli": "^2.8.0"
	}
}
