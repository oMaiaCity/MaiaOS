# Path to a local .litertlm (optional). If unset, a model is auto-downloaded from HuggingFace.
# MODEL_PATH=/path/to/gemma-4-E4B-it.litertlm

# Hugging Face Hub (optional). Used for gated repos and higher rate limits. Both names work:
# HF_TOKEN=hf_...
# HUGGING_FACE_HUB_TOKEN=hf_...
# server.py loads services/parlor/.env first, then the MaiaOS repo root .env (merge, parlor wins).

# HuggingFace LiteRT bundle (default: Gemma 4 E4B). For the smaller E2B model, use:
# HF_REPO=litert-community/gemma-4-E2B-it-litert-lm
# HF_FILENAME=gemma-4-E2B-it.litertlm

# Server port (default: 8000)
# PORT=8000

# Bind address (default: 127.0.0.1 — matches “open in browser” / secure context). Use 0.0.0.0 to listen on all interfaces
# HOST=0.0.0.0


