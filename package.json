{
	"name": "MaiaOS",
	"private": true,
	"workspaces": [
		"services/app",
		"services/aven",
		"services/sync",
		"libs/*"
	],
	"type": "module",
	"scripts": {
		"dev": "bun scripts/dev.js",
		"dev:app": "bun scripts/dev-app.js",
		"dev:sync": "bun scripts/dev-sync.js",
		"dev:aven": "bun --filter @MaiaOS/aven dev",
		"dev:avenos-ui": "bun --filter @AvenOS/ui demo",
		"dev:desktop": "bun scripts/dev-desktop.js",
		"build:desktop": "cd services/app && bun run build && bun run tauri:build && ditto \"src-tauri/target/release/bundle/macos/Maia City.app\" \"/Applications/Maia City.app\" && open \"/Applications/Maia City.app\"",
		"build:desktop:debug": "cd services/app && bun run build && bun run tauri:build:debug && ditto \"src-tauri/target/debug/bundle/macos/Maia City.app\" \"/Applications/Maia City.app\" && open \"/Applications/Maia City.app\"",
		"deploy": "./scripts/deploy-all.sh",
		"deploy:app": "cd services/app && ./deploy.sh",
		"deploy:app:verify": "bun scripts/fly-build-args-verify.js",
		"deploy:sync": "cd services/sync && ./deploy.sh",
		"deploy:aven": "cd services/aven && ./deploy.sh",
		"deploy:landing": "flyctl deploy --dockerfile services/landing/Dockerfile --config services/landing/fly.toml --app maia-city --wait-timeout 300 && flyctl scale count 1 --app maia-city --yes",
		"distros:build": "cd libs/kernel && bun run build",
		"version:sync": "node scripts/sync-version.js",
		"agent:generate": "bun libs/maia-self/scripts/generate-credentials.js",
		"format": "bunx biome format --write .",
		"lint": "bunx biome lint .",
		"check": "bunx biome check .",
		"check:fix": "bunx biome check --write .",
		"check:ci": "bun scripts/lint-import-invariants.mjs && bun scripts/lint-naming-invariants.mjs && bunx biome ci .",
		"migrate:registry": "bun scripts/generate-migrate-registries.mjs",
		"test": "bun scripts/run-workspace-tests.mjs",
		"test:db-contract": "bun --filter @MaiaOS/db test",
		"sentrux:gui": "sentrux scan .",
		"hyperframes:golden:lint": "cd experiments/hyperframes-golden-spiral && bunx hyperframes lint",
		"hyperframes:golden:preview": "cd experiments/hyperframes-golden-spiral && bunx hyperframes preview",
		"hyperframes:golden:render": "cd experiments/hyperframes-golden-spiral && bunx hyperframes render",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@realfavicongenerator/generate-favicon": "0.8.0",
		"@realfavicongenerator/image-adapter-node": "0.8.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0"
	},
	"lint-staged": {
		"*.{js,css,html,md,json}": "biome check --write --no-errors-on-unmatched"
	}
}
