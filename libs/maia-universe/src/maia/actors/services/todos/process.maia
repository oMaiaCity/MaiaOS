{
	"$factory": "°maia/factory/process.factory.maia",
	"handlers": {
		"CREATE_TODO": [
			{
				"op": {
					"create": {
						"factory": "°maia/factory/todos.factory.maia",
						"idempotencyKey": "$$idempotencyKey",
						"data": {
							"text": "$$value",
							"done": false
						}
					}
				}
			},
			{
				"tell": {
					"target": "$$source",
					"type": "SUCCESS",
					"payload": {}
				}
			}
		],
		"TOGGLE_TODO": [
			{
				"op": {
					"update": {
						"id": "$$id",
						"data": {
							"done": {
								"$not": "$$done"
							}
						}
					}
				}
			},
			{
				"tell": {
					"target": "$$source",
					"type": "SUCCESS",
					"payload": {}
				}
			}
		],
		"DELETE_TODO": [
			{
				"op": {
					"delete": {
						"id": "$$id"
					}
				}
			},
			{
				"tell": {
					"target": "$$source",
					"type": "SUCCESS",
					"payload": {}
				}
			}
		],
		"SUCCESS": [
			{
				"ctx": {}
			}
		],
		"ERROR": [
			{
				"ctx": {
					"error": "$$errors.0.message"
				}
			}
		]
	}
}
