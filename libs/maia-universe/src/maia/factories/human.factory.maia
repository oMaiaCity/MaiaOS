{
	"$factory": "°maia/factory/meta.factory.maia",
	"title": "°maia/factory/human.factory.maia",
	"description": "Canonical public identity: account + profile. Referenced by humans registry. View shape includes derived fields (id, accountId, registryName, profileName).",
	"cotype": "comap",
	"indexing": false,
	"properties": {
		"account": {
			"type": "string",
			"pattern": "^co_z[a-zA-Z0-9]{20,}$",
			"description": "Account co-id"
		},
		"profile": {
			"type": "string",
			"pattern": "^co_z[a-zA-Z0-9]{20,}$",
			"description": "Profile co-id"
		},
		"id": {
			"type": "string",
			"pattern": "^co_z[a-zA-Z0-9]+$",
			"description": "Human CoMap co-id (derived when read)"
		},
		"accountId": {
			"type": "string",
			"pattern": "^co_z[a-zA-Z0-9]+$",
			"description": "Same as account, for view"
		},
		"registryName": {
			"type": "string",
			"description": "Registry key (animal-generated, e.g. brave-dolphin-71234567)"
		},
		"profileName": {
			"type": "string",
			"description": "Profile display name from profile.name (resolved when read)"
		},
		"llmExp": {
			"type": "integer",
			"description": "Capability expiry for /llm/chat (Unix seconds). Set at register."
		}
	},
	"required": [
		"account",
		"profile"
	],
	"additionalProperties": false
}
