{
	"$factory": "°maia/factory/meta.factory.maia",
	"title": "°maia/factory/groups.factory.maia",
	"description": "Groups CoMap - guardian, publicReaders. Stored in spark.os.groups",
	"cotype": "comap",
	"indexing": false,
	"properties": {
		"guardian": {
			"type": "string",
			"pattern": "^co_z[a-zA-Z0-9]+$",
			"description": "Guardian group co-id"
		},
		"publicReaders": {
			"type": "string",
			"pattern": "^co_z[a-zA-Z0-9]+$",
			"description": "Public readers group co-id"
		}
	}
}
