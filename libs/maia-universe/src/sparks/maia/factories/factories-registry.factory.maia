	"indexing": false,
	"properties": {
		"°maia/factory/meta.factory.maia": {
			"type": "string",
			"description": "Metaschema co-id (co_z...)"
		}
	},
	"additionalProperties": {
		"type": "string",
		"description": "Schema namekey → schema co-id mapping (e.g., °maia/factory/todo.factory.maia → co_z123...)"
	}
}
