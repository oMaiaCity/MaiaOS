{
	"$factory": "°maia/factory/meta.factory.maia",
	"title": "°maia/factory/factories-registry.factory.maia",
	"description": "Schema registry CoMap - maps schema namekeys (e.g., °maia/factory/todo.factory.maia) to schema co-ids (co_z...). Stored in account.os.factories",
