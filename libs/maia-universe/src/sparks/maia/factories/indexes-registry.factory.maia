{
	"$factory": "°maia/factory/meta.factory.maia",
	"title": "°maia/factory/indexes-registry.factory.maia",
	"description": "Indexes registry CoMap - schema co-id -> index colist. Stored in spark.os.indexes",
	"cotype": "comap",
	"indexing": false,
	"additionalProperties": {
		"type": "string",
		"pattern": "^co_z[a-zA-Z0-9]+$",
		"description": "Schema co-id -> index colist co-id"
	}
}
