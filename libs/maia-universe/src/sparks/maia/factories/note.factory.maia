{
	"$factory": "°maia/factory/meta.factory.maia",
	"title": "°maia/factory/note.factory.maia",
	"cotype": "comap",
	"indexing": true,
	"properties": {
		"title": {
			"type": "string",
			"description": "Note title displayed in the aside list"
		},
		"content": {
			"$co": "°maia/factory/cotext.factory.maia",
			"description": "CoText (colist of graphemes) - collaborative plaintext"
		}
	},
