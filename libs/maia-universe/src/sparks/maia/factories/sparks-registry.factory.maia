{
	"$factory": "°maia/factory/meta.factory.maia",
	"title": "°maia/factory/sparks-registry.factory.maia",
	"description": "Sparks registry CoMap - spark name -> spark co-id. Stored in account.registries.sparks",
	"cotype": "comap",
	"indexing": false,
	"additionalProperties": {
		"type": "string",
		"pattern": "^co_z[a-zA-Z0-9]+$",
		"description": "Spark name -> spark CoMap co-id"
	}
}
