{
	"$factory": "°maia/factory/context.factory.maia",
	"items": {
		"factory": "°maia/factory/aven-identity.factory.maia",
		"map": {
			"id": "id",
			"accountId": "accountId",
			"registryName": "registryName",
			"profileName": "profileName",
			"cardRows": {
				"$mapFields": [
					{
						"label": "Registry name",
						"valuePath": "registryName"
					},
					{
						"label": "Account ID",
						"valuePath": "accountId"
					}
				]
			}
		}
	}
}
