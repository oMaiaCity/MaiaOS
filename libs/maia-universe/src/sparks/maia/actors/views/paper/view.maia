{
	"$factory": "°maia/factory/view.factory.maia",
	"content": {
		"tag": "div",
		"class": "paper-background",
		"children": [
			{
				"tag": "div",
				"class": "paper-scroll",
				"children": [
					{
						"tag": "div",
						"class": "paper-content",
						"text": {
							"$join": [
								{
									"$context": "selectedNote.content.items"
								},
								""
							]
						},
						"format": "md"
					}
				]
			}
		]
	}
}
