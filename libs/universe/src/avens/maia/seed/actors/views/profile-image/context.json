{
	"$factory": "°maia/factory/context.factory.json",
	"title": "Profile Image",
	"scope": {
		"factory": "@scope"
	},
	"profile": {
		"factory": "°maia/factory/profile.factory.json",
		"options": {
			"filter": {
				"id": "$scope.profileId"
			},
			"map": {
				"id": "id",
				"name": "name",
				"avatar": "avatar"
			}
		}
	},
	"uploadStatus": null,
	"uploadError": null,
	"uploadProgressVisible": false,
	"uploadProgressSectionClass": "upload-progress-section upload-progress-section--hidden",
	"uploadProgressPercent": null,
	"uploadProgressStyle": "width: 0%",
	"uploadLoadedBytes": null,
	"uploadTotalBytes": null
}
