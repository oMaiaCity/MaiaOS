{
	"$factory": "°maia/factory/process.factory.json",
	"handlers": {
		"SWITCH_VIEW": [
			{
				"ctx": {
					"viewMode": "$$viewMode"
				}
			},
			{
				"ctx": {
					"currentView": {
						"$find": {
							"array": "$tabs",
							"where": {
								"$eq": ["$$id", "$event.viewMode"]
							},
							"return": "$$actor"
						}
					},
					"tabsWithActive": {
						"$map": {
							"array": "$tabs",
							"return": {
								"id": "$$id",
								"label": "$$label",
								"actor": "$$actor",
								"isActive": {
									"$eq": ["$$id", "$event.viewMode"]
								}
							}
						}
					}
				}
			}
		]
	}
}
