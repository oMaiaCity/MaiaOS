{
	"$factory": "°maia/factory/process.factory.json",
	"handlers": {
		"LOAD_ACTOR": [
			{
				"ctx": {
					"sparkId": "$$id",
					"hasSpark": {
						"$ne": ["$$id", null]
					},
					"showEmptyState": {
						"$eq": ["$$id", null]
					},
					"showContent": {
						"$ne": ["$$id", null]
					}
				}
			}
		],
		"REMOVE_MEMBER": [
			{
				"tell": {
					"target": "°maia/services/spark/actor.json",
					"type": "REMOVE_MEMBER",
					"payload": {
						"id": "$sparkId",
						"memberId": "$$memberId"
					}
				}
			}
		],
		"SUCCESS": [
			{
				"tell": {
					"target": "$inputActor",
					"type": "SUCCESS",
					"payload": {}
				}
			}
		],
		"ERROR": [
			{
				"tell": {
					"target": "$inputActor",
					"type": "ERROR",
					"payload": {
						"errors": "$$errors"
					}
				}
			}
		],
		"FORM_SUBMIT": [
			{
				"tell": {
					"target": "°maia/services/spark/actor.json",
					"type": "ADD_MEMBER",
					"payload": {
						"id": "$sparkId",
						"memberId": "$$value",
						"role": "writer"
					}
				}
			}
		]
	}
}
