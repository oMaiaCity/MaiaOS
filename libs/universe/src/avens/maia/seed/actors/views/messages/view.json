{
	"$factory": "°maia/factory/view.factory.json",
	"content": {
		"tag": "div",
		"class": "messages-content",
		"scrollToBottomOn": "$conversations",
		"children": [
			{
				"tag": "div",
				"class": "welcome-section",
				"children": [
					{
						"tag": "div",
						"class": "message message-assistant welcome-message",
						"attrs": {
							"data": {
								"hasConversations": "$hasConversations"
							}
						},
						"text": "$welcomeText"
					},
					{
						"$each": {
							"items": "$conversations",
							"template": {
								"tag": "div",
								"class": "message-wrapper",
								"attrs": {
									"data": {
										"role": "$$role"
									}
								},
								"children": [
									{
										"tag": "div",
										"class": "message-name",
										"text": "$$displayName"
									},
									{
										"tag": "div",
										"class": "message",
										"attrs": {
											"data": {
												"role": "$$role"
											}
										},
										"text": "$$content"
									}
								]
							}
						}
					},
					{
						"tag": "div",
						"class": "loading",
						"attrs": {
							"data": {
								"isLoading": "$isLoading"
							}
						},
						"text": "$loadingText"
					}
				]
			}
		]
	}
}
