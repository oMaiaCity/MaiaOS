{
	"$factory": "°maia/factory/process.factory.json",
	"handlers": {
		"UPDATE_INPUT_A": [
			{
				"ctx": {
					"inputA": "$$value"
				}
			}
		],
		"UPDATE_INPUT_B": [
			{
				"ctx": {
					"inputB": "$$value"
				}
			}
		],
		"ADD": [
			{
				"ask": {
					"target": "°maia/services/sandboxed-add/actor.json",
					"type": "ADD",
					"payload": {
						"a": "$$a",
						"b": "$$b"
					}
				}
			}
		],
		"SUCCESS": [
			{
				"ctx": {
					"result": "$$result.result",
					"error": null
				}
			}
		],
		"ERROR": [
			{
				"ctx": {
					"error": "$$errors.0.message",
					"result": ""
				}
			}
		]
	}
}
