{
	"$factory": "°maia/factory/meta.factory.json",
	"title": "°maia/factory/identity.factory.json",
	"description": "Unified human/aven identity: type + account + profile. Auto-indexed in spark.os.indexes. Display name from profile.name.",
	"cotype": "comap",
	"indexing": true,
	"properties": {
		"type": {
			"type": "string",
			"enum": ["human", "aven"]
		},
		"account": {
			"type": "string",
			"pattern": "^co_z[a-zA-Z0-9]{20,}$",
			"description": "Account co-id"
		},
		"profile": {
			"type": "string",
			"pattern": "^co_z[a-zA-Z0-9]{20,}$",
			"description": "Profile co-id"
		}
	},
	"required": ["type", "account", "profile"],
	"additionalProperties": false
}
