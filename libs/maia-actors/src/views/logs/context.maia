{
	"$factory": "°Maia/factory/context",
	"$id": "°Maia/actor/views/logs/context",
	"messages": {
		"factory": "°Maia/factory/event",
		"map": {
			"id": "id",
			"type": "type",
			"processed": "processed",
			"payload": "payload",
			"fromRole": "$source.$label",
			"toRole": "$target.$label",
			"fromId": "$source.id",
			"toId": "$target.id",
			"recipient": "$target.$label",
			"targetId": "$target.id"
		}
	},
	"payloadLabel": "payload"
}
