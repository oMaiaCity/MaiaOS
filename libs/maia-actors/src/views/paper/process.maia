{
	"$schema": "°Maia/schema/process",
	"$id": "°Maia/actor/views/paper/process",
	"@label": "@maia/actor/views/paper/process",
	"handlers": {
		"UPDATE_PAPER": [
			{
				"tell": {
					"target": "$contentService",
					"type": "UPDATE_PAPER",
					"payload": {
						"value": "$$value",
						"path": "notes.0.content"
					}
				}
			}
		]
	}
}
