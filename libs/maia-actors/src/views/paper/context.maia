{
	"$schema": "°Maia/schema/context",
	"$id": "°Maia/actor/views/paper/context",
	"contentService": "@contentService",
	"paperService": "@paperService",
	"selectedNoteId": null,
	"selectedNote": {
		"schema": "°Maia/schema/data/notes",
		"filter": {
			"id": "$selectedNoteId"
		},
		"map": {
			"id": "id",
			"content": "$content"
		}
	},
	"@actors": {
		"contentService": "°Maia/actor/services/paper",
		"paperService": "°Maia/actor/services/paper"
	}
}
