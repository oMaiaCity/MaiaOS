{
	"$factory": "°Maia/factory/context",
	"$id": "°Maia/actor/views/addressbook-humans-grid/context",
	"items": {
		"factory": "°Maia/factory/os/human",
		"map": {
			"id": "id",
			"accountId": "accountId",
			"registryName": "registryName",
			"profileName": "profileName",
			"cardRows": {
				"$mapFields": [
					{
						"label": "Registry name",
						"valuePath": "registryName"
					},
					{
						"label": "Account ID",
						"valuePath": "accountId"
					}
				]
			}
		}
	}
}
