{
	"$factory": "°Maia/factory/process",
	"$id": "°Maia/actor/views/layout-paper/process",
	"handlers": {
		"SELECT_NOTE": [
			{
				"ctx": {
					"selectedNoteId": "$$id",
					"selectedNoteIds": {
						"$$id": true
					}
				}
			},
			{
				"tell": {
					"target": "°Maia/actor/views/paper",
					"type": "SELECT_NOTE",
					"payload": {
						"id": "$$id"
					}
				}
			}
		]
	}
}
