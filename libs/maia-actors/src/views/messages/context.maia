{
	"$schema": "°Maia/schema/context",
	"$id": "°Maia/actor/views/messages/context",
	"targetInfoCard": "@infoCard",
	"@actors": {
		"infoCard": "°Maia/actor/views/info-card"
	},
	"conversations": {
		"schema": "°Maia/schema/data/chat",
		"map": {
			"id": "id",
			"role": "role",
			"displayName": "displayName",
			"content": "content"
		}
	},
	"isLoading": false,
	"hasConversations": false,
	"welcomeText": "Hello! How can I assist you today?",
	"loadingText": "Maia is thinking..."
}
