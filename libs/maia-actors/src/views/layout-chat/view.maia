{
	"$factory": "°Maia/factory/view",
	"$id": "°Maia/actor/views/layout-chat/view",
	"content": {
		"tag": "div",
		"class": "chat-container",
		"children": [
			{
				"tag": "div",
				"class": "messages-area",
				"$slot": "$messages"
			},
			{
				"tag": "div",
				"class": "info-area",
				"$slot": "$infoCard"
			},
			{
				"tag": "div",
				"class": "input-area",
				"$slot": "$input"
			}
		]
	}
}
