{
	"$factory": "°maia/factory/process",
	"handlers": {
		"SEND_MESSAGE": [
			{
				"ctx": {
					"_pendingReplyTo": "$$source"
				}
			},
			{
				"ask": {
					"target": "°maia/os/ai/actor.maia",
					"type": "CHAT",
					"payload": {
						"replyTo": "$$source",
						"model": "qwen/qwen3-30b-a3b-instruct-2507",
						"temperature": 1,
						"context": {
							"$concat": [
								[
									{
										"role": "system",
										"content": "You are Maia. Be helpful, technical, and concise. Never use emoticons in your responses. When calling tools, provide actionSummary: a brief human-readable sentence describing what you are doing."
									}
								],
								{
									"$map": {
										"array": "$conversations",
										"as": "msg",
										"return": {
											"role": "$$msg.role",
											"content": "$$msg.content"
										}
									}
								},
								[
									{
										"role": "user",
										"content": "$$inputText"
									}
								]
							]
						}
					}
				}
			}
		],
		"SUCCESS": [
			{
				"tell": {
					"target": "$_pendingReplyTo",
					"type": "SUCCESS",
					"payload": {
						"result": "$$result"
					}
				}
			}
		],
		"ERROR": [
			{
				"tell": {
					"target": "$_pendingReplyTo",
					"type": "ERROR",
					"payload": {
						"errors": "$$errors"
					}
				}
			}
		]
	}
}
