{
	"$factory": "°maia/factory/context",
	"title": "Profile Image",
	"scope": {
		"factory": "@scope"
	},
	"profile": {
		"factory": "°maia/factory/data/profile",
		"filter": {
			"id": "$scope.profileId"
		},
		"map": {
			"id": "id",
			"name": "name",
			"avatar": "avatar"
		}
	},
	"uploadStatus": null,
	"uploadError": null,
	"uploadProgressVisible": false,
	"uploadProgressSectionClass": "upload-progress-section upload-progress-section--hidden",
	"uploadProgressPercent": null,
	"uploadProgressStyle": "width: 0%",
	"uploadLoadedBytes": null,
	"uploadTotalBytes": null
}
